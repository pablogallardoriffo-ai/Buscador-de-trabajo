# IA (necesaria para leer las páginas y hacer el match)
ANTHROPIC_API_KEY=sk-ant-...

# Umbral mínimo de match para guardar/mostrar una oferta (0-100)
MATCH_THRESHOLD=75

# Modelo de Claude (Haiku = barato y rápido, ideal para volumen)
CLAUDE_MODEL=claude-haiku-4-5

# Primera prueba rápida y barata: revisa solo los primeros N sitios (0 = todos)
MAX_SITES=2

# --- Conexión con la plataforma (opcional pero recomendado) ---
# Si defines esto, el bot escribe las ofertas en tu base de datos y aparecen
# en el panel de Es Sencillo. Si lo dejas vacío, solo genera el Excel.
SUPABASE_URL=https://tnntcngconuhyzfavibz.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# Correo del usuario de la plataforma al que se le asignan los matches
TARGET_USER_EMAIL=pablogallardoriffo@gmail.com
